{
    "name": "vhar/laravel-files",
    "description": "Associate files with Eloquent models",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Vhar\\LaravelFiles\\": "src/"
        }
    },
    "authors": [
        {
            "name": "vhar",
            "email": "vhar@mail.ru"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "Vhar\\LaravelFiles\\FileServiceProvider"
            ]
        }
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "phpunit/phpunit": "^11.0"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}